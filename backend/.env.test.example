# Integration tests environment
# Copy this file to .env.test and adjust for your local MySQL:
#   cp .env.test.example .env.test

# Database (must exist: CREATE DATABASE somerch_product_optimizer_test;)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=somerch_product_optimizer_test

# Required for integration tests
STORAGE_DRIVER=database
JWT_SECRET=test-secret
