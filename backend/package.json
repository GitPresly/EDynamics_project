{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend server with Clean Architecture",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --exclude \"./data/**\" src/infrastructure/web/server.ts",
    "build": "tsc",
    "start": "node dist/infrastructure/web/server.js",
    "migration:create": "tsx src/infrastructure/database/createMigration.ts",
    "migrate": "tsx src/infrastructure/database/runMigrations.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "mysql2": "^3.16.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}