# Backend Configuration
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Data Storage
# Path to the JSON file where submissions are stored
# Relative to backend directory or absolute path
DATA_FILE_PATH=./data/submissions.json

# API Configuration
API_BASE_PATH=/api

EASYGIFTS_API_URL=https://easygifts.si/api/v2/7kmuQZkARu86eH9-2QoG/en/sku.json